{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Greenlight",
  "version": "0.1.11",
  "identifier": "com.devorahub-metaviz.greenlight",
  "build": {
    "frontendDist": "dist",
    "devUrl": "http://localhost:3009",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && node scripts/prepare-desktop-resources.mjs"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Greenlight",
        "url": "index.html",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/app": "app",
      "resources/node/node": "binaries/node"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/Devorahub-Metaviz/greenlight/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVFRDY1MjdERTQ5NzI4QTIKUldTaUtKZmtmVkxXWG9NK09OUlBaelY3ZFZCZU4vbGxKU0U2YUdxeXdQRXRIdjkwTDY4N0I4b3QK"
    }
  }
}
